# 复制为 .env 并修改（或用环境变量启动）
PORT=8787
JWT_SECRET=请改成一段随机长字符串
ADMIN_KEY=请改成你的管理员密钥(发码用)
DB_PATH=./data.db

# ===== 客服 / 海外购买（Payoneer 人工收款方案）=====
# 填了 SUPPORT_EMAIL 后：
#   1) 购买页 & 扩展「账号/云同步」面板会显示「联系客服」入口；
#   2) 海外/非大陆用户在购买页 International 标签会看到 Payoneer 购买流程
#      （联系你邮箱 → 你用 Payoneer「Request a Payment」发付款链接收款 → 你在 /admin 生成兑换码发给他 → 他在扩展内兑换开通）。
# 这是 Lemon Squeezy 还没审核通过前的国际收款兜底；等 LS 配好后，International 标签会自动切回 LS 自动收单。
SUPPORT_EMAIL=
# 可选：Payoneer「Request a Payment」生成的固定收款链接。填了则购买页多显示一个「用 Payoneer 付款」按钮，用户可直接点开付款。
# 不填也没关系——用户仍可通过 SUPPORT_EMAIL 联系你，由你手动发 Payoneer 付款请求。
PAYONEER_URL=

# ===== 支付宝（当面付扫码支付，个体工商户即可使用）。不填则站内购买不可用，仍可用兑换码 =====
# 服务器对外可访问地址，支付宝异步通知(notify)用，必须公网可达
# 例：https://api.你的域名  或  http://你的公网IP:8787
PUBLIC_BASE_URL=http://你的公网IP:8787
# 支付宝开放平台应用 APPID
ALIPAY_APP_ID=
# 应用私钥（PKCS8 格式，一行，去掉 -----BEGIN/END----- 头尾与换行）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（在开放平台「接口加签方式」里查看，一行）
ALIPAY_PUBLIC_KEY=
# 网关，正式环境默认即可；沙箱用 https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do


# ===== Lemon Squeezy（国际支付 / 个人即可注册 / 全球多货币）。不填则国际支付不可用 =====
# 面向海外用户：买家可用各国货币/信用卡/PayPal 付款，Lemon Squeezy 换汇+代缴税后，
# 把钱汇总打到你绑定的收款账户（如新加坡 OCBC 走 SGD 银行转账）。
# 价格在 LS 后台按"商品变体(variant)"设置，自动按买家所在地货币结算，无需在此填价格。
#
# 前置：新店铺需先【身份验证 + 审核激活】通过后，才能创建商品、拿到下面这些值。
#
# ---- 逐步获取（审核通过后操作）----
# 1) 建商品：Products → New Product，建 1 个商品配 3 个变体(月/季/年)
#    ★ 务必选【One-time / 单次付款】，不要选 Subscription 订阅！
#      （本服务端只监听 order_created 事件，订阅事件不会给账号开通会员）
# 2) API Key：Settings → API → 新建，复制填 LEMONSQUEEZY_API_KEY
#    （注意区分 Test / Live 模式，两套 Key 不同，测试用 test、上线用 live）
# 3) Store ID：Settings → Stores 里可见；或后台 URL 中的数字，填 LEMONSQUEEZY_STORE_ID
# 4) Webhook：Settings → Webhooks → +
#    - Callback URL 填：<PUBLIC_BASE_URL>/api/lemonsqueezy/webhook
#    - Signing secret 自己设一串随机字符 → 填到 LEMONSQUEEZY_WEBHOOK_SECRET（两处必须一致）
#    - 勾选事件：order_created（至少这个）
# 5) 变体 ID：进入商品 → 点开每个变体(variant)，页面/URL 里的数字即变体 ID，
#    分别填到 _MONTH / _QUARTER / _YEAR
#
# 填完重启服务；扩展"账号/云同步"购买页会出现 International 标签（海外/非大陆默认选中）。
# 建议先小额测试买一单，确认付款后会员自动开通。
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_MONTH=
LEMONSQUEEZY_VARIANT_QUARTER=
LEMONSQUEEZY_VARIANT_YEAR=
